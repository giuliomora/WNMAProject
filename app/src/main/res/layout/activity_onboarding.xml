<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <!-- Logo / icona -->
        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginTop="32dp"
            android:src="@mipmap/ic_launcher_round"
            android:contentDescription="TrekMesh logo" />

        <!-- Titolo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="TrekMesh"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <!-- Sottotitolo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Comunicazione in rete mesh senza connessione"
            android:textSize="14sp"
            android:textColor="#AAFFFFFF"
            android:gravity="center" />

        <!-- Separatore -->
        <View
            android:layout_width="48dp"
            android:layout_height="2dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="24dp"
            android:background="#4CAF50" />

        <!-- Messaggio motivazionale -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ogni dispositivo che partecipa rafforza la rete per tutti.\nSenza permessi, non puoi inviare né ricevere messaggi — e riduci la copertura per chi ti sta intorno."
            android:textSize="15sp"
            android:textColor="#DDFFFFFF"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4" />

        <!-- Sezione permessi -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:layout_marginBottom="16dp"
            android:text="PERMESSI RICHIESTI"
            android:textSize="11sp"
            android:textColor="#884CAF50"
            android:letterSpacing="0.15"
            android:textStyle="bold" />

        <!-- Bluetooth -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="🔵"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bluetooth"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Necessario per scoprire e connettersi ai dispositivi vicini"
                    android:textColor="#AAFFFFFF"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Wi-Fi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="📡"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Wi-Fi Direct"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aumenta la portata della rete fino a 200 metri"
                    android:textColor="#AAFFFFFF"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Posizione GPS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="📍"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Posizione GPS"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Le tue coordinate vengono allegate ai messaggi di emergenza per aiutare i soccorritori a localizzarti. La posizione non viene mai trasmessa senza che tu invii un messaggio."
                    android:textColor="#AAFFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.3"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Notifiche -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="🔔"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Notifiche"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mantiene il servizio attivo in background anche a schermo spento"
                    android:textColor="#AAFFFFFF"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Messaggio errore permessi (nascosto di default) -->
        <TextView
            android:id="@+id/text_permission_denied"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:padding="12dp"
            android:background="#33FF5252"
            android:text="Alcuni permessi sono stati negati. TrekMesh non può funzionare senza di essi. Riaprili dalle impostazioni del dispositivo oppure riprova."
            android:textColor="#FF5252"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Bottone principale -->
        <Button
            android:id="@+id/button_grant_permissions"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="Concedi i permessi ed entra"
            android:textSize="16sp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF" />

        <!-- Link impostazioni (nascosto di default) -->
        <Button
            android:id="@+id/button_open_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Apri impostazioni app"
            android:textSize="14sp"
            android:backgroundTint="@android:color/transparent"
            android:textColor="#AAFFFFFF"
            android:visibility="gone" />

        <View android:layout_width="0dp" android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>
