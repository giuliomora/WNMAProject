<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Indietro"
                android:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Impostazioni"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- Sezione Ruolo -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RUOLO"
            android:textSize="11sp"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_role_icon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:textSize="24sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ruolo attuale"
                            android:textSize="12sp"
                            android:textColor="#888888" />

                        <TextView
                            android:id="@+id/tv_current_role"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_change_role"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cambia"
                        android:textSize="13sp"
                        android:backgroundTint="#2A2A2A"
                        android:textColor="#FFFFFF" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sezione Notifiche -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NOTIFICHE"
            android:textSize="11sp"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <RadioGroup
                android:id="@+id/rg_notification_filter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <RadioButton
                    android:id="@+id/rb_notif_all"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Tutti i messaggi (INFO e SOS)"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:paddingStart="8dp"
                    android:buttonTint="#4CAF50" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:background="#1FFFFFFF" />

                <RadioButton
                    android:id="@+id/rb_notif_sos_only"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Solo SOS"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:paddingStart="8dp"
                    android:buttonTint="#F44336" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:background="#1FFFFFFF" />

                <RadioButton
                    android:id="@+id/rb_notif_info_only"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Solo messaggi informativi"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:paddingStart="8dp"
                    android:buttonTint="#2196F3" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:background="#1FFFFFFF" />

                <RadioButton
                    android:id="@+id/rb_notif_disabled"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Disabilitate"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:paddingStart="8dp"
                    android:buttonTint="#888888" />

            </RadioGroup>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
