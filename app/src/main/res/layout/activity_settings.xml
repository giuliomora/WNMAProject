<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Settings"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- Role section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ROLE"
            android:textSize="11sp"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_role_icon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:textSize="24sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Current role"
                            android:textSize="12sp"
                            android:textColor="#888888" />

                        <TextView
                            android:id="@+id/tv_current_role"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_change_role"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Change"
                        android:textSize="13sp"
                        android:backgroundTint="#2A2A2A"
                        android:textColor="#FFFFFF" />
                </LinearLayout>

                <!-- Node name -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="#2A2A2A" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Your name in the network"
                            android:textSize="12sp"
                            android:textColor="#888888" />

                        <TextView
                            android:id="@+id/tv_node_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textColor="#FFFFFF"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_edit_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Edit"
                        android:textSize="13sp"
                        android:backgroundTint="#2A2A2A"
                        android:textColor="#FFFFFF"
                        android:visibility="gone" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Mesh service section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MESH SERVICE"
            android:textSize="11sp"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_service_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mesh active"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#4CAF50" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Disable when you are not hiking"
                            android:textSize="12sp"
                            android:textColor="#888888"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_mesh_service"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Notifications section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NOTIFICATIONS"
            android:textSize="11sp"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <RadioGroup
                android:id="@+id/rg_notification_filter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <RadioButton
                    android:id="@+id/rb_notif_all"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="All messages (INFO and SOS)"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:paddingStart="8dp"
                    android:buttonTint="#4CAF50" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:background="#1FFFFFFF" />

                <RadioButton
                    android:id="@+id/rb_notif_sos_only"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="SOS only"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:paddingStart="8dp"
                    android:buttonTint="#F44336" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:background="#1FFFFFFF" />

                <RadioButton
                    android:id="@+id/rb_notif_info_only"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Info messages only"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:paddingStart="8dp"
                    android:buttonTint="#2196F3" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:background="#1FFFFFFF" />

                <RadioButton
                    android:id="@+id/rb_notif_disabled"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Disabled"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:paddingStart="8dp"
                    android:buttonTint="#888888" />

            </RadioGroup>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
