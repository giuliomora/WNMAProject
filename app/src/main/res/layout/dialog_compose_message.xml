<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Tipo: INFO / SOS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tipo messaggio"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btn_type_info"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="INFO"
                android:textSize="14sp"
                android:backgroundTint="#2196F3" />

            <Button
                android:id="@+id/btn_type_sos"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="SOS"
                android:textSize="14sp"
                android:backgroundTint="#44F44336" />

            <Button
                android:id="@+id/btn_type_broadcast"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="AVVISO"
                android:textSize="14sp"
                android:backgroundTint="#FF9800"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Priorità -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Priorità"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/radio_priority"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <RadioButton
                android:id="@+id/radio_priority_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1 – Bassa"
                android:checked="true" />

            <RadioButton
                android:id="@+id/radio_priority_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2 – Media" />

            <RadioButton
                android:id="@+id/radio_priority_3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="3 – Alta" />
        </RadioGroup>

        <!-- Testo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Messaggio *"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/edit_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Testo del messaggio"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:maxLines="4"
            android:layout_marginBottom="16dp" />

        <!-- Descrizione -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Descrizione (facoltativa)"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/edit_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Dettagli aggiuntivi..."
            android:inputType="textMultiLine"
            android:minLines="2"
            android:maxLines="6"
            android:layout_marginBottom="16dp" />

        <!-- Immagine -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Foto (facoltativa)"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="8dp" />

        <ImageView
            android:id="@+id/image_preview"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:scaleType="centerCrop"
            android:background="#11000000"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btn_pick_image"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Aggiungi foto"
                android:backgroundTint="#666666" />

            <Button
                android:id="@+id/btn_remove_image"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Rimuovi"
                android:backgroundTint="#666666"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Pulsanti azione -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Annulla"
                android:backgroundTint="@android:color/transparent"
                android:textColor="#888888" />

            <Button
                android:id="@+id/btn_send"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Invia"
                android:backgroundTint="#4CAF50" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
