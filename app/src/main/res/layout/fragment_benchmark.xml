<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Status card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_bench_peers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="● Peers: 0"
                        android:textColor="#4CAF50"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_bench_mode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mode: —"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_battery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔋 —%"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Section: DISCOVERY & RECOVERY -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DISCOVERY &amp; RECOVERY"
            android:textSize="10sp"
            android:textColor="#666666"
            android:letterSpacing="0.1"
            android:paddingStart="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp">

            <Button
                android:id="@+id/btn_rediscovery"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Re-Discovery"
                android:backgroundTint="#1565C0"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btn_recovery_series"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Blackout ×5"
                android:backgroundTint="#BF360C"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp">

            <Button
                android:id="@+id/btn_rediscovery_series_low"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="×10 LOW"
                android:backgroundTint="#0D47A1"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btn_rediscovery_series_high"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="×10 HIGH"
                android:backgroundTint="#1B5E20"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp">

            <Button
                android:id="@+id/btn_rssi_snap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="RSSI Snapshot"
                android:backgroundTint="#4527A0"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Section: THROUGHPUT -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="THROUGHPUT"
            android:textSize="10sp"
            android:textColor="#666666"
            android:letterSpacing="0.1"
            android:paddingStart="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp">

            <Button
                android:id="@+id/btn_throughput_100k"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="×5  100KB"
                android:backgroundTint="#00695C"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btn_throughput_500k"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="×5  500KB"
                android:backgroundTint="#004D40"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Section: TRAFFIC & STRESS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TRAFFIC &amp; STRESS"
            android:textSize="10sp"
            android:textColor="#666666"
            android:letterSpacing="0.1"
            android:paddingStart="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp">

            <Button
                android:id="@+id/btn_packet_loss"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="×5  Packet Loss"
                android:backgroundTint="#2E7D32"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btn_stress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="×5  Stress"
                android:backgroundTint="#6A1B9A"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Section: BATTERY -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BATTERY"
            android:textSize="10sp"
            android:textColor="#666666"
            android:letterSpacing="0.1"
            android:paddingStart="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp">

            <Button
                android:id="@+id/btn_battery_start"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Battery Start"
                android:backgroundTint="#37474F"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btn_battery_end"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Battery End"
                android:backgroundTint="#263238"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="→ See BenchLog tab for the full log"
            android:textSize="11sp"
            android:textColor="#555555"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="12dp" />

    </LinearLayout>
</ScrollView>
